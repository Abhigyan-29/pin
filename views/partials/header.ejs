<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>pix</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { theme: { extend: {} } }</script>
</head>
<body class="bg-[#0a0a0f] text-[#f1f1f5]">
  <div class="mesh-bg"></div>

  <% if (nav === true) { %>
  <header class="glass-effect sticky top-0 z-50 h-[60px] flex items-center px-5 gap-4">

    <!-- Logo -->
    <a href="/" class="font-bold text-lg tracking-tight text-white shrink-0 flex items-center gap-2">
      <div class="w-7 h-7 rounded-lg overflow-hidden bg-violet-600 flex items-center justify-center">
        <img src="/images/logo.png" class="w-full h-full object-cover" alt="pix" onerror="this.style.display='none'">
      </div>
      pix
    </a>

    <!-- Search -->
    <div class="relative w-[380px] ml-6 hidden md:block">
      <div id="search-box" class="flex items-center bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.08)] rounded-xl px-3 py-2 gap-2 focus-within:border-violet-500/50 transition-all">
        <i class="ri-search-line text-[#52525b] text-sm shrink-0"></i>
        <input
          id="search-input"
          type="text"
          placeholder="Search photos..."
          class="bg-transparent outline-none text-sm text-white placeholder-[#52525b] flex-1 min-w-0"
          value="<%= locals.query || '' %>"
          autocomplete="off"
        />
        <button id="search-clear" class="text-[#52525b] hover:text-white transition-colors shrink-0" style="display:none">
          <i class="ri-close-line text-sm"></i>
        </button>
      </div>

      <!-- Smart Dropdown -->
      <div id="search-dropdown">
        <div class="px-4 pt-3 pb-1.5">
          <p class="text-[10px] text-[#52525b] uppercase tracking-widest font-semibold">Browse topics</p>
        </div>
        <div id="suggestions-list" class="max-h-64 overflow-y-auto pb-2"></div>
      </div>
    </div>

    <!-- Nav actions -->
    <div class="flex items-center gap-2 shrink-0 ml-auto">
      <% if (user) { %>
        <a href="/add" class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-[#a1a1aa] hover:text-white border border-[rgba(255,255,255,0.08)] rounded-lg hover:border-white/20 transition-all">
          <i class="ri-add-line"></i> Upload
        </a>
        <a href="/profile" class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center text-white font-bold text-xs shrink-0 hover:scale-105 transition-transform">
          <%= user.name ? user.name[0].toUpperCase() : 'U' %>
        </a>
        <a href="/logout" class="px-3 py-1.5 text-xs font-medium text-[#a1a1aa] hover:text-white transition-colors">Logout</a>
      <% } else { %>
        <a href="/feed" class="px-3 py-1.5 text-xs font-medium text-[#a1a1aa] hover:text-white transition-colors">Explore</a>
        <a href="/login" class="px-4 py-1.5 text-xs font-semibold text-white bg-violet-600 hover:bg-violet-500 rounded-lg transition-colors">Login</a>
      <% } %>
    </div>
  </header>

  <script>
    const TOPICS = [
      {e:"🚗",l:"Cars",v:"cars"},{e:"🏙️",l:"Architecture",v:"architecture"},
      {e:"🌿",l:"Nature",v:"nature"},{e:"🌌",l:"Space",v:"space"},
      {e:"🤖",l:"Cyberpunk",v:"cyberpunk"},{e:"🎨",l:"Abstract",v:"abstract"},
      {e:"🦁",l:"Animals",v:"animals"},{e:"🏔️",l:"Mountains",v:"mountains"},
      {e:"🌊",l:"Ocean",v:"ocean"},{e:"🌸",l:"Flowers",v:"flowers"},
      {e:"🏍️",l:"Motorcycles",v:"motorcycles"},{e:"✈️",l:"Travel",v:"travel"},
      {e:"🍕",l:"Food",v:"food"},{e:"🌆",l:"City",v:"city"},
      {e:"💡",l:"Technology",v:"technology"},{e:"👗",l:"Fashion",v:"fashion"},
      {e:"🌅",l:"Sunset",v:"sunset"},{e:"🏖️",l:"Beach",v:"beach"},
      {e:"🌙",l:"Night",v:"night"},{e:"❄️",l:"Winter",v:"winter"},
      {e:"🔥",l:"Fire",v:"fire"},{e:"🏛️",l:"Monuments",v:"monuments"},
      {e:"🧊",l:"Minimal",v:"minimal"},{e:"💎",l:"Luxury",v:"luxury"},
      {e:"📷",l:"Photography",v:"photography"},{e:"🎸",l:"Music",v:"music"},
      {e:"🎭",l:"Art",v:"art"},{e:"🏄",l:"Surf",v:"surf"},
      {e:"🌺",l:"Tropical",v:"tropical"},{e:"🦋",l:"Macro",v:"macro"},
    ];

    const input   = document.getElementById('search-input');
    const drop    = document.getElementById('search-dropdown');
    const list    = document.getElementById('suggestions-list');
    const clearBtn= document.getElementById('search-clear');

    function renderList(filter) {
      const items = filter
        ? TOPICS.filter(t => t.l.toLowerCase().includes(filter.toLowerCase()) || t.v.includes(filter.toLowerCase()))
        : TOPICS;
      list.innerHTML = items.map(t =>
        `<button onclick="go('${t.v}')" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-[#d4d4d8] hover:bg-white/5 hover:text-white transition-colors text-left">
          <span class="text-base">${t.e}</span> <span>${t.l}</span>
        </button>`
      ).join('');
    }

    function go(val) {
      window.location.href = '/feed?q=' + encodeURIComponent(val);
    }

    function openDrop() { renderList(input.value); drop.classList.add('show'); }
    function closeDrop() { drop.classList.remove('show'); }

    input.addEventListener('focus', openDrop);
    input.addEventListener('input', () => {
      const v = input.value.trim();
      clearBtn.style.display = v ? 'block' : 'none';
      renderList(v);
      if (!drop.classList.contains('show')) openDrop();
      if (!v) {
        clearTimeout(window._clearTimer);
        window._clearTimer = setTimeout(() => { if (!input.value.trim()) window.location.href = '/feed'; }, 800);
      }
    });
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const q = input.value.trim();
        closeDrop();
        window.location.href = q ? `/feed?q=${encodeURIComponent(q)}` : '/feed';
      }
      if (e.key === 'Escape') closeDrop();
    });
    clearBtn.addEventListener('click', () => {
      input.value = ''; clearBtn.style.display = 'none'; closeDrop();
      window.location.href = '/feed';
    });
    document.addEventListener('click', e => {
      if (!e.target.closest('#search-box') && !e.target.closest('#search-dropdown')) closeDrop();
    });
    if (input.value) clearBtn.style.display = 'block';
  </script>
  <% } %>