<% include ./partials/header.ejs%>

<div class="w-full min-h-screen pt-12 px-8 pb-20 flex justify-center">
    <div class="w-full max-w-2xl">
        <div class="glass-card rounded-[2.5rem] p-12 border border-white/10 shadow-2xl relative overflow-hidden">
            <!-- Decorative Glow -->
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-cyan-500/10 blur-[100px]"></div>
            
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-violet-500 to-cyan-400 flex items-center justify-center shadow-lg shadow-violet-500/20">
                    <i class="ri-add-line text-2xl text-white"></i>
                </div>
                <div>
                    <h1 class="text-3xl font-extrabold text-white tracking-tighter">Initialize <span class="bg-gradient-to-r from-violet-400 to-cyan-400 bg-clip-text text-transparent">Transmission</span></h1>
                    <p class="text-zinc-500 text-sm font-medium">Capture a moment and sync it to the future.</p>
                </div>
            </div>

            <form action="/createpost" method="POST" enctype="multipart/form-data" class="space-y-6">
                <!-- File Input -->
                <div class="group relative">
                    <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2 px-1">Visual Signal Data</label>
                    <div class="relative w-full h-40 border-2 border-dashed border-white/10 rounded-2xl flex flex-col items-center justify-center bg-white/5 hover:bg-white/10 transition-all cursor-pointer group">
                        <i class="ri-upload-cloud-2-line text-4xl text-zinc-600 group-hover:text-violet-400 transition-colors mb-2"></i>
                        <span class="text-sm text-zinc-500 group-hover:text-zinc-300 font-medium tracking-tight">Drop signal here or click to browse</span>
                        <input class="absolute inset-0 opacity-0 cursor-pointer" type="file" name="postimage" required>
                    </div>
                </div>

                <!-- Title -->
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 px-1">Signal Hash (Title)</label>
                    <input class="cyber-input w-full px-5 py-4 rounded-xl text-sm" type="text" placeholder="Enter a descriptive title..." name="title" required>
                </div>

                <!-- Description -->
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 px-1">Detailed Log (Description)</label>
                    <textarea class="cyber-input w-full px-5 py-4 rounded-xl text-sm min-h-[160px] resize-none" placeholder="What is the story behind this transmission?" name="description"></textarea>
                </div>

                <!-- Submit Button -->
                <div class="pt-4">
                    <button type="submit" class="w-full py-4 btn-glow text-white rounded-xl font-bold uppercase tracking-widest text-sm shadow-xl shadow-violet-500/20 flex items-center justify-center gap-3">
                        Launch Transmission <i class="ri-rocket-line"></i>
                    </button>
                    <a href="/profile" class="block text-center mt-4 text-xs font-semibold text-zinc-600 hover:text-zinc-400 transition-colors">Abort Protocol</a>
                </div>
            </form>
        </div>
    </div>
</div>

<% include ./partials/footer.ejs%>