<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> · pix</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0a0a0f] text-[#f1f1f5]">
<div class="mesh-bg"></div>

<!-- Nav -->
<header class="glass-effect sticky top-0 z-50 h-[60px] flex items-center px-5 gap-4">
  <a href="/feed" class="flex items-center gap-2 text-[#71717a] hover:text-white transition-colors text-sm">
    <i class="ri-arrow-left-line"></i> Back
  </a>
  <a href="/" class="font-bold text-base tracking-tight text-white mx-auto flex items-center gap-2">
    <div class="w-6 h-6 rounded-md overflow-hidden bg-violet-600">
      <img src="/images/logo.png" class="w-full h-full object-cover" alt="pix" onerror="this.style.display='none'">
    </div>
    pix
  </a>
  <% if (user) { %>
    <a href="/profile" class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center text-white font-bold text-xs">
      <%= user.name[0].toUpperCase() %>
    </a>
  <% } else { %>
    <a href="/login" class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors">Login</a>
  <% } %>
</header>

<!-- Content -->
<main class="max-w-5xl mx-auto px-4 py-8 flex flex-col lg:flex-row gap-8 items-start">

  <!-- Image -->
  <div class="w-full lg:flex-1 rounded-2xl overflow-hidden bg-[#111118] flex items-center justify-center">
    <img
      src="<%= post.image.startsWith('http') ? post.image : '/images/uploads/' + post.image %>"
      alt="<%= post.title %>"
      class="w-full h-auto max-h-[80vh] object-contain"
    >
  </div>

  <!-- Info panel -->
  <aside class="w-full lg:w-80 shrink-0 flex flex-col gap-5 lg:sticky lg:top-[76px]">

    <!-- Creator -->
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-500 to-cyan-500 flex items-center justify-center text-sm font-bold text-white shrink-0">
          <%= post.user && post.user.name ? post.user.name[0].toUpperCase() : 'U' %>
        </div>
        <div>
          <p class="text-sm font-semibold text-white"><%= post.user ? post.user.name : 'Curator' %></p>
          <p class="text-xs text-[#71717a]">@<%= post.user ? post.user.username : 'system_bot' %></p>
        </div>
      </div>
      <% if(user && user.saved.map(String).indexOf(String(post._id)) === -1) { %>
        <a href="/save/<%= post._id %>" class="btn-glow px-4 py-2 text-white text-xs font-semibold rounded-lg">Save</a>
      <% } else if(user) { %>
        <span class="text-xs text-violet-400 font-semibold flex items-center gap-1"><i class="ri-check-line"></i> Saved</span>
      <% } %>
    </div>

    <!-- Title -->
    <div>
      <h1 class="text-2xl font-bold text-white tracking-tight leading-snug"><%= post.title %></h1>
      <% if(post.description) { %>
        <p class="text-sm text-[#71717a] mt-2 leading-relaxed"><%= post.description %></p>
      <% } %>
    </div>

    <!-- Actions -->
    <div class="flex flex-col gap-2 pt-4 border-t border-[rgba(255,255,255,0.06)]">
      <a href="/download/<%= post._id %>"
        class="btn-glow flex items-center justify-center gap-2 py-3 text-white text-sm font-semibold rounded-xl">
        <i class="ri-download-2-line text-base"></i> Download
      </a>
      <div class="grid grid-cols-2 gap-2">
        <button
          onclick="if(navigator.share) navigator.share({title:'<%= post.title %>',url:location.href})"
          class="btn-ghost flex items-center justify-center gap-1.5 py-2.5 text-sm rounded-xl font-medium">
          <i class="ri-share-forward-line"></i> Share
        </button>
        <button
          id="copy-btn"
          onclick="navigator.clipboard.writeText(location.href);this.textContent='✓ Copied'"
          class="btn-ghost flex items-center justify-center gap-1.5 py-2.5 text-sm rounded-xl font-medium">
          <i class="ri-link"></i> Copy link
        </button>
      </div>
    </div>

  </aside>
</main>

</body>
</html>
