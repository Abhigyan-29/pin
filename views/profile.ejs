<% include ./partials/header.ejs %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <!-- Hidden upload form -->
  <form id="uploadform" hidden action="/fileupload" method="POST" enctype="multipart/form-data">
    <input type="file" name="image" accept="image/*">
  </form>

  <!-- Profile header -->
  <div class="flex flex-col sm:flex-row items-center sm:items-end gap-6 mb-8 pb-8 border-b border-[rgba(255,255,255,0.06)]">
    <div class="relative shrink-0">
      <div class="w-20 h-20 rounded-full overflow-hidden ring-2 ring-violet-500/30">
        <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profileImage %>" alt="<%= user.name %>">
      </div>
      <button id="uploadicon"
        class="absolute -bottom-1 -right-1 w-7 h-7 bg-white text-black rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-transform">
        <i class="ri-pencil-line text-xs"></i>
      </button>
    </div>
    <div class="text-center sm:text-left flex-1">
      <h1 class="text-2xl font-bold text-white"><%= user.name %></h1>
      <p class="text-sm text-[#71717a]">@<%= user.username %></p>
    </div>
    <div class="flex items-center gap-3">
      <div class="text-center px-4 py-2 glass-card rounded-xl">
        <p class="text-lg font-bold text-white"><%= user.posts.length %></p>
        <p class="text-[10px] text-[#52525b] uppercase tracking-wider">Uploads</p>
      </div>
      <div class="text-center px-4 py-2 glass-card rounded-xl">
        <p class="text-lg font-bold text-white"><%= user.saved.length %></p>
        <p class="text-[10px] text-[#52525b] uppercase tracking-wider">Saved</p>
      </div>
    </div>
    <a href="/add" class="btn-glow px-4 py-2 text-white text-sm font-semibold rounded-lg flex items-center gap-1.5">
      <i class="ri-add-line"></i> New Pin
    </a>
  </div>

  <!-- Content -->
  <div>
    <h2 class="text-sm font-semibold text-[#71717a] uppercase tracking-widest mb-4">Your uploads</h2>

    <% if(user.posts.length > 0) { %>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        <% user.posts.forEach(function(post) { %>
          <% const img = post.image; %>
          <a href="/pin/<%= post._id %>" class="relative group aspect-square rounded-xl overflow-hidden glass-card block">
            <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              src="<%= img && img.startsWith('http') ? img : '/images/uploads/' + img %>"
              alt="<%= post.title %>">
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all flex items-end p-2 opacity-0 group-hover:opacity-100">
              <p class="text-white text-xs font-medium line-clamp-2"><%= post.title %></p>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="glass-card rounded-2xl p-16 text-center">
        <i class="ri-image-line text-4xl text-[#27272a] block mb-3"></i>
        <p class="text-[#52525b] text-sm mb-4">No photos uploaded yet.</p>
        <a href="/add" class="btn-glow px-5 py-2.5 text-white text-sm font-semibold rounded-lg inline-block">Upload your first pin</a>
      </div>
    <% } %>
  </div>

</div>

<script>
document.querySelector('#uploadicon').addEventListener('click', () =>
  document.querySelector('#uploadform input').click()
);
document.querySelector('#uploadform input').addEventListener('change', () =>
  document.querySelector('#uploadform').submit()
);
</script>

<% include ./partials/footer.ejs %>